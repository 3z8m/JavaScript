// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}


// ワークロール
model Workroll {
  id                    String  @id @default(cuid())
  roll_id               String
  roll_type             String
  grinding_type         String
  grinding_amount       Float
  diameter_rg           Float
  diameter_ml           Float?
  ra_i                  Float?
  ra_h                  Float?
  width                 Float?
  judgement             String
  comment               String?
  operation_date        String
  grinding_number       String
  processing_time       Float
  non_processing_code1  String?
  non_processing_time1  Float?
  non_processing_code2  String?
  non_processing_time2  Float?
  non_processing_code3  String?
  non_processing_time3  Float?
  non_processing_code4  String?
  non_processing_time4  Float?
  non_processing_code5  String?
  non_processing_time5  Float?
  operator              String
  operation_group       String
  status                String
}

// 中間ロール
model Imroll {
  id                    String  @id @default(cuid())
  taper_code            String
  imr_set_code          String
  imr_id                String
  cylindricity1         Float
  cylindricity2         Float
  cylindricity3         Float
  cylindricity4         Float
  cylindricity5         Float
  pair_diff             Float
  imr_diameter_before   Float
  imr_diameter_after    Float
  grinding_amount       Float
  grinding_type         String?
  imr_ra                Float?
  judgement             String
  comment               String?
  operation_date        String
  processing_time       Float?
  non_processing_code1  String?
  non_processing_time1  Float?
  non_processing_code2  String?
  non_processing_time2  Float?
  non_processing_code3  String?
  non_processing_time3  Float?
  non_processing_code4  String?
  non_processing_time4  Float?
  non_processing_code5  String?
  non_processing_time5  Float?
  operator              String
  operation_group       String
  status                String
}