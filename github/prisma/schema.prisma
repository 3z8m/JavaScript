generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}


// ワークロール
model Workroll {
  id              String  @id @default(cuid())
  roll_id         String
  roll_type       String
  grinding_type   String
  grinding_amount Float
  diameter        Float
  ra_i            Float
  ra_h            Float
  judgement       String
  comment         String?
  operation_date  String
  start_time      String
  end_time        String
  operator        String
  operation_group String
}

